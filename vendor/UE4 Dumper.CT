                  <ID>26118</ID>
                  <Description>"DissectCode (Memory View -&gt; Ctrl+J or (Tools -&gt; Dissect code) )"</Description>
                  <Options moHideChildren="1"/>
                  <GroupHeader>1</GroupHeader>
